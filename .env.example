# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# Telethon API Configuration (get from https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Media Simulation Settings (optional)
# Maximum retries for media sending (default: 2)
MEDIA_MAX_RETRIES=2
# Delay between retry attempts in seconds (default: 1.0)
MEDIA_RETRY_DELAY=1.0
